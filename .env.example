# EmailJS — obtén estos valores en https://www.emailjs.com/
# 1. Crea una cuenta gratuita
# 2. Agrega un servicio de email (Gmail, Outlook, etc.)
# 3. Crea una plantilla con las variables: empresa, contacto, email, sector, nivel, descripcion
# 4. Copia los IDs aquí y renombra este archivo a .env

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

# Resend API key (server). Do NOT commit your real key to git.
# Example: RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_ZbjuAtLd_4ehAo83UePZRkSybZuvg5pmM
